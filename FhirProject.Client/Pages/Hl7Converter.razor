@page "/hl7-converter"
@using FhirProject.Shared
@using FhirProject.Shared.Dtos
@using FhirProject.Client.Services
@inject ApiClient Api

<PageTitle>HL7 v2 Converter</PageTitle>

<h1>HL7 v2 &rarr; FHIR Converter</h1>
<p class="text-muted">
    Paste a raw HL7 v2 message and convert it into the equivalent FHIR R4 resources.
</p>

<div class="mb-3">
    <div class="form-check form-check-inline">
        <input class="form-check-input" type="radio" id="adtType" checked="@(_messageType == MessageType.Adt)"
               @onchange="() => _messageType = MessageType.Adt" />
        <label class="form-check-label" for="adtType">ADT^A01 (admit/register)</label>
    </div>
    <div class="form-check form-check-inline">
        <input class="form-check-input" type="radio" id="oruType" checked="@(_messageType == MessageType.Oru)"
               @onchange="() => _messageType = MessageType.Oru" />
        <label class="form-check-label" for="oruType">ORU^R01 (lab result)</label>
    </div>
</div>

<textarea class="form-control mb-2" rows="8" style="font-family: monospace;" @bind="_rawMessage"
          placeholder="Paste a raw HL7 v2 message here..."></textarea>

<button class="btn btn-outline-secondary me-2" @onclick="LoadSample">Load sample</button>
<button class="btn btn-primary" @onclick="ConvertAsync" disabled="@_isLoading">Convert</button>

@if (_isLoading)
{
    <p class="mt-3"><em>Converting...</em></p>
}
else if (_errorMessage is not null)
{
    <div class="alert alert-danger mt-3">@_errorMessage</div>
}

@if (_result is not null)
{
    <div class="row mt-4">
        <div class="col-md-6">
            <h4>Raw Segments</h4>
            @foreach (var segment in _result.Segments)
            {
                <div class="mb-2">
                    <strong>@segment.Name</strong>
                    <div class="small text-muted" style="font-family: monospace; white-space: pre-wrap;">
                        @string.Join(" | ", segment.Fields)
                    </div>
                </div>
            }
        </div>
        <div class="col-md-6">
            <h4>Generated FHIR Resources</h4>
            @foreach (var resourceJson in _result.FhirResourcesJson)
            {
                <pre class="bg-light p-2 border" style="max-height: 300px; overflow: auto;">@resourceJson</pre>
            }
        </div>
    </div>
}

@code {
    private enum MessageType { Adt, Oru }

    private MessageType _messageType = MessageType.Adt;
    private string _rawMessage = string.Empty;
    private Hl7ConversionResultDto? _result;
    private bool _isLoading;
    private string? _errorMessage;

    private void LoadSample()
    {
        _rawMessage = _messageType == MessageType.Adt ? Hl7SampleMessages.SampleAdt : Hl7SampleMessages.SampleOru;
        _result = null;
        _errorMessage = null;
    }

    private async Task ConvertAsync()
    {
        if (string.IsNullOrWhiteSpace(_rawMessage))
        {
            return;
        }

        _isLoading = true;
        _errorMessage = null;
        _result = null;
        StateHasChanged();

        try
        {
            _result = _messageType == MessageType.Adt
                ? await Api.ParseAdtAsync(_rawMessage)
                : await Api.ParseOruAsync(_rawMessage);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Conversion failed: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }
}
